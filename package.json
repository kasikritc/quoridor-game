{
  "name": "quoridor-game",
  "version": "0.1.0",
  "private": true,
  "description": "Rules-enforced Quoridor web game with a bot-ready API boundary.",
  "license": "MIT",
  "type": "module",
  "scripts": {
    "dev": "concurrently \"tsx watch server/index.ts\" \"vite --host 0.0.0.0\"",
    "server": "tsx watch server/index.ts",
    "client": "vite --host 0.0.0.0",
    "build": "tsc -p tsconfig.json && tsc -p tsconfig.node.json && vite build",
    "check": "tsc -p tsconfig.json && tsc -p tsconfig.node.json && vitest run"
  },
  "dependencies": {
    "@vitejs/plugin-react": "^4.2.1",
    "concurrently": "^8.2.2",
    "express": "^4.18.3",
    "lucide-react": "^0.468.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "tsx": "^4.7.1",
    "vite": "^5.1.4"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/node": "^20.11.24",
    "@types/react": "^18.2.61",
    "@types/react-dom": "^18.2.19",
    "typescript": "^5.3.3",
    "vitest": "^1.3.1"
  }
}
